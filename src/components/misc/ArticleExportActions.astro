---
import { Icon } from "astro-icon/components";
import { getPostUrlBySlug, removeFileExtension, url } from "@/utils/url-utils";

interface Props {
	slug: string;
	title: string;
}

const { slug, title } = Astro.props;
const normalizedSlug = removeFileExtension(slug);
const markdownUrl = url(`/downloads/${normalizedSlug}.md`);
---

<div class="article-export-actions onload-animation" aria-label="文章导出">
	<div class="article-export-actions__text">
		<span>EXPORT NODE</span>
		<strong>{title}</strong>
	</div>
	<div class="article-export-actions__buttons">
		<a href={markdownUrl} download={`${normalizedSlug}.md`} class="article-export-actions__button">
			<Icon name="material-symbols:markdown-outline-rounded" />
			<span>下载 MD</span>
		</a>
		<button type="button" class="article-export-actions__button" data-print-pdf>
			<Icon name="material-symbols:picture-as-pdf-outline-rounded" />
			<span>导出 PDF</span>
		</button>
		<a href={getPostUrlBySlug(slug)} class="article-export-actions__button article-export-actions__button--ghost">
			<Icon name="material-symbols:article-outline-rounded" />
			<span>文章页</span>
		</a>
	</div>
</div>

<script>
	document.querySelectorAll("[data-print-pdf]").forEach((button) => {
		button.addEventListener("click", () => {
			window.print();
		});
	});
</script>

<style>
	.article-export-actions {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		margin-bottom: 1.25rem;
		padding: 1rem;
		border: 1px solid rgba(125, 211, 252, 0.2);
		border-radius: 0.75rem;
		background:
			linear-gradient(135deg, rgba(12, 18, 38, 0.82), rgba(12, 11, 26, 0.72)),
			rgba(8, 12, 26, 0.76);
		color: rgb(226, 232, 240);
		backdrop-filter: blur(16px);
	}

	.article-export-actions__text {
		min-width: 0;
	}

	.article-export-actions__text span {
		display: block;
		color: rgba(125, 211, 252, 0.78);
		font-family: Orbitron, Rajdhani, sans-serif;
		font-size: 0.72rem;
		font-weight: 800;
		letter-spacing: 0.08em;
	}

	.article-export-actions__text strong {
		display: block;
		overflow: hidden;
		margin-top: 0.2rem;
		color: rgb(248, 250, 252);
		text-overflow: ellipsis;
		white-space: nowrap;
	}

	.article-export-actions__buttons {
		display: flex;
		flex-wrap: wrap;
		gap: 0.6rem;
		justify-content: flex-end;
	}

	.article-export-actions__button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.4rem;
		min-height: 2.45rem;
		padding: 0 0.85rem;
		border: 1px solid rgba(34, 211, 238, 0.45);
		border-radius: 999px;
		background: linear-gradient(135deg, rgba(34, 211, 238, 0.18), rgba(168, 85, 247, 0.18));
		color: rgb(248, 250, 252);
		font-size: 0.85rem;
		font-weight: 800;
		transition:
			transform 160ms ease,
			border-color 160ms ease;
	}

	.article-export-actions__button:hover {
		transform: translateY(-2px);
		border-color: rgba(34, 211, 238, 0.75);
	}

	.article-export-actions__button svg {
		width: 1.1rem;
		height: 1.1rem;
	}

	.article-export-actions__button--ghost {
		background: rgba(15, 23, 42, 0.55);
	}

	@media (max-width: 640px) {
		.article-export-actions {
			align-items: stretch;
			flex-direction: column;
		}

		.article-export-actions__buttons {
			justify-content: flex-start;
		}
	}

	@media print {
		.article-export-actions {
			display: none;
		}
	}
</style>
